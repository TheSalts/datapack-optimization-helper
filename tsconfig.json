{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2022",
        "lib": ["ES2022", "ESNext"],
        "sourceMap": true,
        "rootDir": "src",
        "resolveJsonModule": true,
        "strict": true /* enable all strict type-checking options */,
        "types": ["node", "mocha", "vscode"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", ".vscode-test"]
}
